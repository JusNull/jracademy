{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "求职匠 Job Hunter",
  "description": "AI job hunting assistant. Extract JD from Seek/LinkedIn/Indeed/Glassdoor, get AI analysis and interview prep.",
  "version": "0.9.18",
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "scripting",
    "tabs",
    "cookies",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.seek.com.au/*",
    "https://seek.com.au/*",
    "https://www.seek.co.nz/*",
    "https://seek.co.nz/*",
    "https://www.linkedin.com/*",
    "https://au.indeed.com/*",
    "https://www.indeed.com/*",
    "https://nz.indeed.com/*",
    "https://www.glassdoor.com.au/*",
    "https://www.glassdoor.com/*",
    "https://www.glassdoor.co.nz/*",
    "https://au.gradconnection.com/*",
    "https://nz.gradconnection.com/*",
    "https://api.jiangren.com.au/*",
    "https://jiangren.com.au/*",
    "http://localhost:3010/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-loader-pp0CyXJK.js"
      ],
      "matches": [
        "https://www.seek.com.au/*",
        "https://seek.com.au/*",
        "https://www.seek.co.nz/*",
        "https://seek.co.nz/*",
        "https://www.linkedin.com/*",
        "https://au.indeed.com/viewjob*",
        "https://au.indeed.com/jobs*",
        "https://au.indeed.com/rc/clk*",
        "https://www.indeed.com/viewjob*",
        "https://www.indeed.com/jobs*",
        "https://www.indeed.com/rc/clk*",
        "https://nz.indeed.com/viewjob*",
        "https://nz.indeed.com/jobs*",
        "https://nz.indeed.com/rc/clk*",
        "https://www.glassdoor.com.au/job-listing/*",
        "https://www.glassdoor.com.au/partner/jobListing*",
        "https://www.glassdoor.com/job-listing/*",
        "https://www.glassdoor.com/partner/jobListing*",
        "https://www.glassdoor.co.nz/job-listing/*",
        "https://www.glassdoor.co.nz/partner/jobListing*",
        "https://au.gradconnection.com/employers/*/jobs/*",
        "https://nz.gradconnection.com/employers/*/jobs/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "resources": [
        "public/icons/icon-32.png"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://au.gradconnection.com/*",
        "https://au.indeed.com/*",
        "https://au.indeed.com/*",
        "https://au.indeed.com/*",
        "https://nz.gradconnection.com/*",
        "https://nz.indeed.com/*",
        "https://nz.indeed.com/*",
        "https://nz.indeed.com/*",
        "https://seek.co.nz/*",
        "https://seek.com.au/*",
        "https://www.glassdoor.co.nz/*",
        "https://www.glassdoor.co.nz/*",
        "https://www.glassdoor.com.au/*",
        "https://www.glassdoor.com.au/*",
        "https://www.glassdoor.com/*",
        "https://www.glassdoor.com/*",
        "https://www.indeed.com/*",
        "https://www.indeed.com/*",
        "https://www.indeed.com/*",
        "https://www.linkedin.com/*",
        "https://www.seek.co.nz/*",
        "https://www.seek.com.au/*"
      ],
      "resources": [
        "assets/skills-dictionary-BT-g3aHx.js",
        "assets/platforms-rowJjw7g.js",
        "assets/message-quick-reply-ZccPv1C6.js",
        "assets/feed-scanner-BF3zmnOW.js",
        "assets/alumni-badge-injector-BSQQwPhL.js",
        "assets/profile-extractor-C60-IxP0.js",
        "assets/company-extractor-CrNOACrk.js",
        "assets/profile-seo-scorer-IkisyKoF.js",
        "assets/message-extractor-CJ8WBAnx.js",
        "assets/message-classifier-BJDQzvHu.js",
        "assets/connections-extractor-Cx0cr5Rt.js",
        "assets/connections-classifier-dx_cOAZq.js",
        "assets/post-injector-CtAdnmgd.js",
        "assets/content-script.ts-JvBoJEXM.js"
      ],
      "use_dynamic_url": false
    }
  ],
  "commands": {
    "extract-job": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "Extract job data and open sidebar"
    },
    "quick-analyze": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Quick analyze current job posting"
    }
  }
}
